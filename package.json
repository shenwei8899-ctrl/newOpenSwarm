{
  "name": "openswarm-saas",
  "private": true,
  "packageManager": "pnpm@8.11.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @openswarm/web dev",
    "dev:api": "pnpm --filter @openswarm/api dev",
    "dev:worker": "pnpm --filter @openswarm/worker dev",
    "db:generate": "pnpm --filter @openswarm/db db:generate",
    "db:migrate:dev": "pnpm --filter @openswarm/db db:migrate:dev",
    "db:push": "pnpm --filter @openswarm/db db:push",
    "db:seed": "pnpm --filter @openswarm/db db:seed",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.1",
    "typescript": "^5.6.2"
  }
}
